# ============================================================
# ENSIIE RAG Chatbot — Environment Configuration
# Copy to .env and adjust paths as needed
# ============================================================

# --- Data Paths (swap mock → real by changing these) ---
RAW_DOCUMENTS_PATH=../share/raw_documents.jsonl
CHUNKS_PATH=../share/chunks.jsonl
EMBEDDINGS_PATH=../share/embeddings.npy
CHUNK_IDS_PATH=../share/chunk_ids.json
FAISS_INDEX_PATH=../share/faiss_index.index

DB_PATH=../share/documents.db
SCRAPER_OUTPUT_DIR=../share/scraper_output
PDF_DIR=../share/pdf_documents
LINKEDIN_POSTS_PATH=../share/linkedin_posts.json

# --- Embedding Model ---
EMBEDDING_MODEL=intfloat/e5-large-v2

# --- Retrieval ---
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# --- LLM Settings ---
LLM_MODEL=ollama/mistral
LLM_BASE_URL=http://localhost:11434
MAX_TOKENS=1024
TEMPERATURE=0.3

# --- Dry-Run Mode (skip LLM call, return template response) ---
DRY_RUN=true

# --- API Settings ---
CORS_ORIGINS=["http://localhost:3000","https://ensiie.fr"]
HOST=0.0.0.0
PORT=8000

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=100
CHUNKING_STRATEGY=recursive
